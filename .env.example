# ================================
# CONFIGURATION BIBLIOTHÈQUE API
# ================================

# Securité — OBLIGATOIRE en production
DEBUG=False
SECRET_KEY=your-very-secret-key-here-change-this-in-production

# Hôtes autorisés (séparés par virgules)
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com

# Base de données PostgreSQL (laisser vide pour SQLite en local)
DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS — URLs du frontend autorisées
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.com
