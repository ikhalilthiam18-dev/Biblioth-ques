{
  "version": 2,
  "builds": [
    {
      "src": "bibliotheque_project/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11",
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "bibliotheque_project/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "bibliotheque_project.settings",
    "DEBUG": "False"
  }
}